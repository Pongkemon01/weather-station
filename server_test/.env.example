# Copy to .env and fill in — .env is gitignored.
#
# External (Nginx) URL — used with real mTLS device cert.
BASE_URL=https://robin-gpu.cpe.ku.ac.th
#
# Internal FastAPI URL — reached via SSH tunnel or on the server itself.
# Used for header-injection tests (T1-8) and when mTLS is not yet deployed.
#   ssh -L 8000:127.0.0.1:8000 akp@robin-gpu.cpe.ku.ac.th -N &
INTERNAL_URL=http://127.0.0.1:8000
#
# Private CA chain PEM — used to verify the server cert over mTLS.
CA_BUNDLE=/path/to/pki/private_ca_chain.pem
#
# Shared device client certificate + key (all devices share one cert per Arch §2.1).
DEVICE_CERT=/path/to/pki/devices/weather-test/weather-test-chain.pem
DEVICE_KEY=/path/to/pki/devices/weather-test/weather-test.key
#
# Read-only asyncpg DSN for DB assertions.
# On the server: postgresql:///weather?host=/var/run/postgresql
# Via SSH tunnel: postgresql://akp@localhost:5433/weather
TEST_DB_DSN=postgresql:///weather?host=/var/run/postgresql
#
# Absolute path to the server's firmware/ directory — must be writable from the
# test runner. When running tests on the server: /home/akp/html/firmware
# Via SSHFS mount: /mnt/iot-firmware  (mount with: sshfs akp@robin-gpu.cpe.ku.ac.th:/home/akp/html/firmware /mnt/iot-firmware)
FIRMWARE_DIR=/home/akp/html/firmware
