{
  "title": "IoT Weather Station",
  "uid": "iot-weather",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Ingest rate (records/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(ingest_chunks_total[5m])",
          "legendFormat": "records/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 2,
      "title": "Duplicate uploads (rate)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(ingest_duplicates_total[5m])",
          "legendFormat": "duplicates/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "orange" } }
      }
    },
    {
      "id": 3,
      "title": "Ingest lag p95",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ingest_lag_seconds_bucket[10m])) by (le))",
          "legendFormat": "p95 lag"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 120 },
              { "color": "red", "value": 300 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "OTA chunks served (rate)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(ota_chunks_served_total[5m])",
          "legendFormat": "chunks/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 5,
      "title": "mTLS cert-verify failures (rate)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(cert_verify_failures_total[1m])",
          "legendFormat": "{{ reason }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "OTA campaign success rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "ota_campaign_success_rate",
          "legendFormat": "campaign {{ campaign_id }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Device heartbeat (last seen)",
      "type": "table",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 10 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "options": { "footer": { "show": false } },
      "targets": [
        {
          "rawSql": "SELECT region_id, station_id, EXTRACT(EPOCH FROM (now() - last_seen))::int AS lag_seconds, last_seen FROM devices ORDER BY last_seen ASC",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "lag_seconds" },
            "properties": [
              { "id": "unit", "value": "s" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 43200 },
                    { "color": "red", "value": 86400 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      }
    },
    {
      "id": 8,
      "title": "OTA rollout progress per campaign",
      "type": "table",
      "gridPos": { "x": 0, "y": 34, "w": 24, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "options": { "footer": { "show": false } },
      "targets": [
        {
          "rawSql": "SELECT c.id, c.version, c.status, c.rollout_window_days, c.success_rate, COUNT(DISTINCT dc.device_id) AS devices_started, CEIL(c.firmware_size::float / 512) AS total_chunks FROM ota_campaigns c LEFT JOIN download_completions dc ON dc.campaign_id = c.id WHERE c.status NOT IN ('draft', 'cancelled') GROUP BY c.id ORDER BY c.id DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ]
}
