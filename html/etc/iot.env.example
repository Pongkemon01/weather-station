# Copy this file to iot.env and fill in real values before starting the service.
# This file is committed; iot.env is git-ignored.

DB_DSN=postgresql://akp@localhost/weather
JWT_SECRET=change-me-to-a-long-random-secret
FIRMWARE_DIR=/home/akp/html/firmware
FIRMWARE_KEEP_N=3
SLOT_LEN_SEC=43200
MAX_FIRMWARE_SIZE_BYTES=491520

# Used only by scripts/migrate.py at provisioning time to seed the admin user.
# Remove or blank after first migration; never needed at runtime.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password
